# 警察庁の犯罪統計CSVファイル（Shift-JIS）
/data/

# Claude Code project files
# Claude Codeの設定・キャッシュファイル
/.claude/

# OS files
.DS_Store
Thumbs.db

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~
